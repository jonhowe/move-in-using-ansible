---
# Copy this file to .env.yml and override only the values you want to change.
# The file is YAML even though the name starts with ".env" so nested Ansible
# variables remain easy to override.

user: yourusername
group: yourusername
home_directory: /home/yourusername

docker_add_user_to_group: true
downloads_migrate_existing: true

git_user_name: Example User
git_user_email: user@example.com

pipx_packages:
  - httpie

applications:
  - name: signal-desktop
    repo: "deb [arch=amd64] https://updates.signal.org/desktop/apt xenial main"
    key_url: https://updates.signal.org/desktop/apt/keys.asc

snaps_regular:
  - brave
  - drawing
  - remmina
  - plex-desktop
  - bitwarden

optional_snap_applications:
  - name: joplin
    enabled: true
    install_method: snap
    snap_name: joplin-desktop
    classic: false
    channel: stable
  - name: todoist
    enabled: true
    install_method: snap
    snap_name: todoist
    classic: false
    channel: stable
  - name: zoom
    enabled: true
    install_method: snap
    snap_name: zoom-client
    classic: false
    channel: stable
  - name: rambox
    enabled: true
    install_method: snap
    snap_name: rambox
    classic: false
    channel: stable

synaptics_repository_keyring_deb_checksum: ""
