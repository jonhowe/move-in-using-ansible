{
    "$schema": "https://opencode.ai/config.json",
    "agent": {
    "build": {
        "mode": "primary",
        "model": "litellm/openai/gpt-5.3-codex",
        "tools": {
            "write": true,
            "edit": true,
            "bash": true    
        }
    },
    "plan": {
        "mode": "primary",
        "model": "litellm/openai/gpt-5.4",
        "tools": {
            "write": false,
            "edit": false,
            "bash": false
        }
    },
    "code-reviewer": {
        "description": "Reviews code for best practices and potential issues",
        "mode": "subagent",
        "model": "litellm/Grok Code Fast 1",
        "prompt": "You are a code reviewer. Focus on security, performance, and maintainability.",
        "tools": {
            "write": false,
            "edit": false   
        }
    }
    },
    "plugin": ["@ramtinj95/opencode-tokenscope"],
    "provider": {
    "litellm": {
        "npm": "@ai-sdk/openai-compatible",
        "name": "LiteLLM",
        "options": {
            "baseURL": "http://192.168.1.106:4001/v1"
        },
        "models": {
            "openai/gpt-5.3-codex": {
                "name": "openai/gpt-5.3-codex",
                "cost": {
                    "input": 0.00003,
                    "output": 0.00012
                },
                "limit": {
                    "context": 128000,
                    "output": 16000
                }
            },
            "openai/gpt-5.4": {
                "name": "openai/gpt-5.4",
                "cost": {
                    "input": 0.000004,
                    "output": 0.000016
                },
                "limit": {
                    "context": 128000,
                    "output": 4096
                }
            },
            "xai/grok-code-fast-1": {
                "name": "xai/grok-code-fast-1",
                "cost": {
                    "input": 0.00002,
                    "output": 0.00008
                },
                "limit": {
                    "context": 128000,
                    "output": 16000
                }
            },
            "anthropic/claude-haiku-4-5-20251001": {
                "name": "anthropic/claude-haiku-4-5-20251001",
                "cost": {
                    "input": 0.00008,
                    "output": 0.0004
                },
                "limit": {
                    "context": 200000,
                    "output": 4096
                }
            },
            "anthropic/claude-sonnet-4-6": {
                "name": "anthropic/claude-sonnet-4-6",
                "cost": {
                    "input": 0.003,
                    "output": 0.015
                },
                "limit": {
                    "context": 200000,
                    "output": 16000
                }
            },
            "anthropic/claude-opus-4-6": {
                "name": "anthropic/claude-opus-4-6",
                "cost": {
                    "input": 0.015,
                    "output": 0.075
                },
                "limit": {
                    "context": 200000,
                    "output": 16000
                }
            }
        }
    },
    "myriad360": {
        "npm": "@ai-sdk/openai-compatible",
        "name": "Myriad360",
        "options": {
            "baseURL": "http://192.168.1.106:4001/v1"
        },
        "models": {
            "myriad360-gpt-5.4": {
                "name": "myriad360-gpt-5.4",
                "cost": {
                    "input": 0.00003,
                    "output": 0.00012
                },
                "limit": {
                    "context": 128000,
                    "output": 16000
                }
            },
            "myriad360-gpt-5.3-codex": {
                "name": "myriad360-gpt-5.3-codex",
                "cost": {
                    "input": 0.00003,
                    "output": 0.00012
                },
                "limit": {
                    "context": 128000,
                    "output": 16000
                }
            }
        }
    }
    }
}
